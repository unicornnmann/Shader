local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

local noclip = false
local viewTarget

local function findPlayer(name)
	name = name:lower()

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.Name:lower():sub(1,#name) == name then
			return plr
		end

		if plr.DisplayName:lower():sub(1,#name) == name then
			return plr
		end
	end
end

local function giveTPTool()
	local backpack = player:WaitForChild("Backpack")

	local old = backpack:FindFirstChild("TP Tool")
	if old then
		old:Destroy()
	end

	local tool = Instance.new("Tool")
	tool.Name = "TP Tool"
	tool.RequiresHandle = false
	tool.Parent = backpack

	tool.Activated:Connect(function()
		local mouse = player:GetMouse()

		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			player.Character.HumanoidRootPart.CFrame =
				CFrame.new(mouse.Hit.Position + Vector3.new(0,3,0))
		end
	end)
end

game:GetService("RunService").Stepped:Connect(function()
	if noclip and player.Character then
		for _, v in ipairs(player.Character:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end
end)

player.Chatted:Connect(function(msg)
	local args = string.split(msg, " ")
	local cmd = args[1]:lower()

	if cmd == ";rs" then
		local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if hum then
			hum.Health = 0
		end

	elseif cmd == ";tp" then
		giveTPTool()

	elseif cmd == ";goto" then
		local target = findPlayer(args[2] or "")

		if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
			local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")

			if hrp then
				hrp.CFrame =
					target.Character.HumanoidRootPart.CFrame
					+ Vector3.new(0,3,0)
			end
		end

	elseif cmd == ";ws" then
		local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")

		if hum and tonumber(args[2]) then
			hum.WalkSpeed = tonumber(args[2])
		end

	elseif cmd == ";jp" then
		local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")

		if hum and tonumber(args[2]) then
			hum.JumpPower = tonumber(args[2])
		end

	elseif cmd == ";sit" then
		local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")

		if hum then
			hum.Sit = true
		end

	elseif cmd == ";rejoin" then
		TeleportService:Teleport(game.PlaceId, player)

	elseif cmd == ";fov" then
		if tonumber(args[2]) then
			camera.FieldOfView = tonumber(args[2])
		end

	elseif cmd == ";gravity" then
		if tonumber(args[2]) then
			Workspace.Gravity = tonumber(args[2])
		end

	elseif cmd == ";noclip" then
		noclip = true

	elseif cmd == ";clip" then
		noclip = false

		if player.Character then
			for _, v in ipairs(player.Character:GetDescendants()) do
				if v:IsA("BasePart") then
					v.CanCollide = true
				end
			end
		end

	elseif cmd == ";view" then
		local target = findPlayer(args[2] or "")

		if target and target.Character and target.Character:FindFirstChild("Humanoid") then
			camera.CameraSubject = target.Character.Humanoid
			viewTarget = target
		end

	elseif cmd == ";unview" then
		local hum = player.Character and player.Character:FindFirstChild("Humanoid")

		if hum then
			camera.CameraSubject = hum
			viewTarget = nil
		end
	end
end)

